# 开发阶段可以使用 *，方便本地页面和扩展调试。
# 生产阶段建议改成明确来源，例如：https://app.example.com,chrome-extension://你的扩展ID
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Authorization,Accept,X-Requested-With
CORS_EXPOSE_HEADERS=Content-Length
CORS_ALLOW_CREDENTIALS=false
