OSS_PREVIEW_URL_TTL_SECONDS=900

AI_PROVIDER=aliyun
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen3.6-plus
BAILIAN_API_KEY=
DASHSCOPE_API_KEY=

MAX_USER_INFLIGHT_AI=3
CONVERSATION_LOCK_SECONDS=180
IDEMPOTENCY_TTL_HOURS=24
