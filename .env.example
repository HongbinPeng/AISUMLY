# === 容器初始化密码（仅 Docker Compose 使用）===
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password
RABBITMQ_DEFAULT_USER=aisumly
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password

# === 后端应用配置 ===
APP_ADDR=:8080
GIN_MODE=debug

# MySQL 连接串（Docker 部署用 mysql，本地开发用 127.0.0.1）
MYSQL_DSN=your_username:your_password@tcp(mysql:3306)/aisumly?charset=utf8mb4&parseTime=True&loc=Local

# Redis 连接（Docker 部署用 redis，本地开发用 127.0.0.1）
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置（生产环境请更换为强随机字符串）
JWT_SECRET=your_jwt_secret
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_HOURS=336

# 阿里云 OSS 配置
OSS_ENDPOINT=https://oss-cn-wuhan-lr.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=your_bucket_name
OSS_PUBLIC_BASE_URL=
OSS_UPLOAD_URL_TTL_SECONDS=900
OSS_PREVIEW_URL_TTL_SECONDS=900

# AI 模型配置（阿里云百炼）
AI_PROVIDER=aliyun
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen3.6-plus
BAILIAN_API_KEY=your_api_key
DASHSCOPE_API_KEY=your_api_key

# 安全限制
MAX_USER_INFLIGHT_AI=3
CONVERSATION_LOCK_SECONDS=180
IDEMPOTENCY_TTL_HOURS=24
RECENT_CONTEXT_TTL_DAYS=7
